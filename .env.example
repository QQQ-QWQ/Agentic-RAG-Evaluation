# =============================================================================
# 使用方式：复制本文件为 `.env`（`.env` 已在 .gitignore，切勿提交）
#
# 以下路径为本地运行时产物，同样勿提交（见仓库根目录 .gitignore）：
#   - runs/logs/          实验 JSONL、global_audit.jsonl、会话 chat/trace
#   - runs/results/       批量评测 CSV 等
#   - data/processed/chunks.jsonl、documents.csv  （kb sync 后生成）
#   - data/raw/session_upload|user_docs|web_snapshots/
#
# 提交代码前请用 `git status` 确认未暂存 .env、日志或 processed 数据。
# =============================================================================

# LLM API（若使用 OpenAI 官方接口可填此处）
OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
MODEL_NAME=gpt-4o-mini

# DeepSeek（main.py agent / 编排第一层与第二层 / 部分 RAG 对话）；未填时回退使用上面的 OPENAI_API_KEY
DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_CHAT_MODEL=deepseek-chat

# Volcengine Ark embedding, used by imported local RAG demo code
ARK_API_KEY=
# ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# ARK_EMBEDDING_MODEL=doubao-embedding-vision-250615
# ARK_EMBEDDING_DIMENSIONS=2048

# Chroma（本地向量缓存，与 src/agentic_rag/rag/chroma_store.py 对应）
# 默认 E:\agentic_rag_chroma；无 E 盘请改为本机路径
# CHROMA_PERSIST_DIRECTORY=E:\agentic_rag_chroma

# Embedding / Rerank
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
RERANK_MODEL=BAAI/bge-reranker-base

# Firecrawl 网页抓取 / 搜索（第二层 topic4_firecrawl_* 工具；见 https://docs.firecrawl.dev/zh/introduction）
# FIRECRAWL_API_KEY=fc-your-api-key
# FIRECRAWL_MAX_OUTPUT_CHARS=80000
# FIRECRAWL_SEARCH_LIMIT=5

# Agent 编排：本地 Python 沙箱（subprocess + 临时目录；非 Docker）
# SANDBOX_ENABLED=false
# SANDBOX_TIMEOUT_SEC=60
# SANDBOX_MAX_CODE_CHARS=50000

# C4 工程内写盘 / shell（path_policy 禁止 .env、.git 等）
# FILE_WRITE_ENABLED=true
# SHELL_COMMAND_ENABLED=true
# SHELL_TIMEOUT_SEC=60

# Project settings
DEFAULT_TOP_K=5
RERANK_TOP_K=5
MAX_RETRIEVAL_ROUNDS=2
